<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Article Automator - المؤتمت الذكي"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_gravity="center"
        android:layout_marginBottom="16dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <EditText
            android:id="@+id/new_rss_url"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="رابط RSS جديد"/>
        <Button
            android:id="@+id/add_rss_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="إضافة"/>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rss_recycler"
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:layout_marginTop="8dp"
        android:background="#F5F5F5"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp"
        android:gravity="center">
        <Button
            android:id="@+id/auth_blogger"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Blogger"
            android:layout_marginEnd="4dp"/>
        <Button
            android:id="@+id/auth_pinterest"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pinterest"
            android:layout_marginEnd="4dp"/>
        <Button
            android:id="@+id/settings_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚙️"/>
    </LinearLayout>

    <Button
        android:id="@+id/start_worker"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="بدء الجدولة الآلية"
        android:layout_marginTop="8dp"
        android:backgroundTint="#4CAF50"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="سجل العمليات:"
        android:layout_marginTop="16dp"
        android:textStyle="bold"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/log_recycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="4dp"
        android:background="#E0E0E0"/>

</LinearLayout>
